# ==============================
# YesNoQuest .gitignore
# ==============================

# Gradle
.gradle/
build/
out/

# Kotlin / JVM
*.class

# Keep Gradle Wrapper JAR
!gradle/wrapper/gradle-wrapper.jar

# Spring Boot build artifacts
*.jar
*.war

# IDE
.idea/
.idea/runConfigurations/
*.iml
*.ipr
*.iws
.vscode/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets / env
.env
.env.*
application-local.properties
application-dev.properties

# H2 (persistent + files)
data/
*.mv.db
*.trace.db

# Logs
logs/
*.log

# Temp
*.tmp
*.swp
*.lock
tmp/
temp/

# Node (if ever added)
node_modules/

# Coverage
coverage/