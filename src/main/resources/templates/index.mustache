<!doctype html>
<html>
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>YesNoQuest</title>

    <style>
        body{
            margin:0;
            font-family:system-ui;
            background:#0b0b0c;
            color:#f3f4f6;
            padding:24px
        }

        a{color:#60a5fa;text-decoration:none}

        .card{
            margin-top:16px;
            background:#141416;
            border:1px solid #262626;
            border-radius:18px;
            padding:18px;
            max-width:1100px;
        }

        label{
            display:block;
            margin:12px 0 6px;
            color:#cbd5e1
        }

        input, textarea, select{
            width:100%;
            padding:12px;
            border-radius:12px;
            border:1px solid #2a2a2a;
            background:#0f0f10;
            color:#f3f4f6
        }

        button{
            margin-top:14px;
            width:100%;
            padding:12px;
            border-radius:12px;
            border:none;
            background:#22c55e;
            color:#0b0b0c;
            font-weight:800;
            cursor:pointer
        }

        .msg{
            margin-top:10px;
            color:#9ca3af;
            font-size:13px
        }

        .ok{
            margin-top:12px;
            padding:12px;
            border-radius:12px;
            border:1px solid #2a2a2a;
            background:#0f0f10
        }

        /* Layout for preview */
        .row{
            display:grid;
            grid-template-columns:1fr;
            gap:24px
        }

        @media (min-width: 980px){
            .row{
                grid-template-columns:1fr 1fr
            }
        }

        .previewTitle{
            margin:0 0 10px;
            color:#cbd5e1;
            font-size:14px
        }

        .previewFrame{
            width:100%;
            height:420px;
            border:1px solid #2a2a2a;
            border-radius:14px;
            background:#0f0f10
        }
    </style>
</head>

<body>

<!-- Logout -->
<form method="post" action="/logout" style="display:inline;">
    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
    <button type="submit"
            style="background:none;border:none;color:#60a5fa;cursor:pointer;padding:0;font:inherit;">
        Logout
    </button>
</form>

<div class="card">
    <h2>Create a “Yes/No” trap</h2>

    <div class="row">

        <!-- LEFT SIDE: FORM -->
        <div>
            <form method="post" action="/send">

                <label>Recipient email</label>
                <input type="email"
                       name="recipientEmail"
                       required
                       placeholder="someone@example.com"/>

                <label>One question</label>
                <textarea name="question"
                          rows="3"
                          required
                          placeholder="Will you go out with me?"
                          id="questionInput"></textarea>

                <label>Theme</label>
                <select name="theme"
                        required
                        id="themeSelect">
                    {{#themes}}
                        <option value="{{name}}">{{label}}</option>
                    {{/themes}}
                </select>

                <input type="hidden"
                       name="{{_csrf.parameterName}}"
                       value="{{_csrf.token}}">

                <button type="submit">Generate & Send</button>

                <div class="msg">
                    It emails an HTML file. “NO” runs away and does nothing 😈
                </div>
            </form>

            {{#sentTo}}
                <div class="ok">
                    ✅ Sent to <b>{{sentTo}}</b><br/>
                    Attachment: <b>{{fileName}}</b>
                </div>
            {{/sentTo}}

            {{#mailError}}
                <div class="ok" style="border-color:#f87171;">
                    ❌ Email failed: <b>{{mailError}}</b>
                </div>
            {{/mailError}}
        </div>

        <!-- RIGHT SIDE: LIVE PREVIEW -->
        <div>
            <div class="previewTitle">
                Live preview (what they’ll open)
            </div>

            <iframe class="previewFrame"
                    id="previewFrame"
                    sandbox="allow-scripts">
            </iframe>

            <div class="msg">
                Preview updates as you type or change theme.
            </div>
        </div>

    </div>
</div>

<!-- Preview Script -->
<script>
    const questionInput = document.getElementById("questionInput");
    const themeSelect = document.getElementById("themeSelect");
    const previewFrame = document.getElementById("previewFrame");

    function refreshPreview() {
        const question = encodeURIComponent(questionInput.value || "");
        const theme = encodeURIComponent(themeSelect.value);
        previewFrame.src = `/preview?theme=${theme}&question=${question}`;
    }

    let timer = null;

    function scheduleRefresh() {
        clearTimeout(timer);
        timer = setTimeout(refreshPreview, 200);
    }

    questionInput.addEventListener("input", scheduleRefresh);
    themeSelect.addEventListener("change", refreshPreview);

    // Initial render
    refreshPreview();
</script>

</body>
</html>